# Шаблон переменных окружения. Реальные значения — в .env (НЕ в git).
# anon/publishable-ключ публичен; пароль БД и service_role — секреты, не коммитить.

# Публичный URL проекта
SUPABASE_URL=https://kolrwuhjjsclqalapfzt.supabase.co

# Transaction pooler (IPv4, порт 6543) — для применения миграций и тестов против облака (scripts/db, scripts/import).
# Пароль БД берётся в Dashboard → Connect → Session pooler (тот же), порт меняем на 6543. Спецсимволы URL-экранировать.
SUPABASE_DB_URL=postgresql://postgres.kolrwuhjjsclqalapfzt:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# --- Фронтенд (Vite). Реальные значения — в .env.local (НЕ в git). anon/publishable-ключ публичен. ---
VITE_SUPABASE_URL=https://kolrwuhjjsclqalapfzt.supabase.co
VITE_SUPABASE_ANON_KEY=<publishable-ключ sb_publishable_... из Dashboard → Settings → API Keys>

# --- Telegram-напоминания (scripts/telegram, обычно запускается GitHub Actions) ---
TELEGRAM_BOT_TOKEN=<токен от @BotFather>
TELEGRAM_CHAT_ID=<id группового чата, отрицательное число>
